<!DOCTYPE html>
<html lang="<%= I18n.locale %>" dir="<%= text_direction %>" class="antialiased">
  <head>
    <%= display_meta_tags(default_meta_tags) %>

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="view-transition" content="same-origin">
    <meta name="application-name" content="pastehtml.dev">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="pastehtml">
    <meta name="theme-color" content="#fff8ec">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% unless paste_origin_request? %>
      <%# PWA manifest for installable apps (routes are defined in config/routes.rb).
          The manifest fetch carries no cookie, so non-default locales travel in the href. %>
      <%= tag.link rel: "manifest", href: (I18n.locale == I18n.default_locale ? pwa_manifest_path : pwa_manifest_path(locale: I18n.locale)) %>
    <% end %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://rsms.me/">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bangers&family=IBM+Plex+Mono:wght@400;500&display=swap">
    <%# Arabic comic + text faces, loaded only when the page is Arabic so English stays lean. %>
    <% if I18n.locale == :ar %>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600&family=Lalezar&display=swap">
    <% end %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-paper font-sans text-ink"<% unless paste_origin_request? %> data-controller="pwa"<% end %>>
    <div class="isolate flex min-h-dvh flex-col overflow-x-clip">
      <a href="#main" class="sr-only focus-visible:not-sr-only focus-visible:absolute focus-visible:start-3 focus-visible:top-3 focus-visible:z-50 focus-visible:rounded-md focus-visible:border-3 focus-visible:border-ink focus-visible:bg-white focus-visible:px-4 focus-visible:py-2 focus-visible:font-display focus-visible:text-ink focus-visible:shadow-comic-sm"><%= t("layout.skip_to_content") %></a>
      <header class="flex items-center justify-between gap-4 px-6 py-5 sm:px-10">
        <a href="/" class="-rotate-1 border-3 border-ink bg-white px-3 py-1 font-display text-2xl tracking-wide shadow-comic-sm">
          pastehtml<span class="text-hero-red">.dev</span>
        </a>
        <div class="flex flex-wrap items-center justify-end gap-3">
          <nav aria-label="<%= t("layout.primary_nav") %>" class="flex flex-wrap items-center gap-3">
          <% if authenticated? %>
            <% dashboard_current = current_nav?(:dashboard) %>
            <%= link_to t("layout.dashboard"), pastes_path,
                  aria: { current: ("page" if dashboard_current) },
                  class: "rotate-1 border-2 border-ink px-2.5 py-1 font-display text-sm tracking-wide shadow-comic-sm #{dashboard_current ? "bg-ink text-paper" : "bg-hero-yellow text-ink hover:bg-white"}" %>
            <% api_keys_current = current_nav?(:api_keys) %>
            <%= link_to t("layout.api_keys"), api_keys_path,
                  aria: { current: ("page" if api_keys_current) },
                  class: "-rotate-1 border-2 border-ink px-2.5 py-1 font-display text-sm tracking-wide shadow-comic-sm #{api_keys_current ? "bg-ink text-paper" : "bg-white text-ink hover:bg-hero-yellow"}" %>
            <%= button_to t("layout.sign_out"), session_path, method: :delete,
                  class: "border-2 border-ink bg-white px-2.5 py-1 font-display text-sm tracking-wide text-ink shadow-comic-sm hover:bg-hero-yellow" %>
          <% else %>
            <% sign_in_current = current_nav?(:sign_in) %>
            <%= link_to t("layout.sign_in"), new_session_path,
                  aria: { current: ("page" if sign_in_current) },
                  class: "rotate-2 border-2 border-ink px-2.5 py-1 font-display text-sm tracking-wide shadow-comic-sm #{sign_in_current ? "bg-ink text-paper" : "bg-white text-ink hover:bg-hero-yellow"}" %>
            <% sign_up_current = current_nav?(:sign_up) %>
            <%= link_to t("layout.sign_up"), new_user_path,
                  aria: { current: ("page" if sign_up_current) },
                  class: "-rotate-1 border-2 border-ink px-2.5 py-1 font-display text-sm tracking-wide shadow-comic-sm #{sign_up_current ? "bg-ink text-paper" : "bg-hero-yellow text-ink hover:bg-white"}" %>
          <% end %>
          </nav>
          <%= locale_toggle %>
        </div>
      </header>

      <main id="main" class="flex flex-1 flex-col">
        <% flash.each do |type, message| %>
          <% next if message.blank? %>
          <div class="mx-auto mt-2 w-[calc(100%-3rem)] max-w-4xl rounded-lg border-3 border-ink <%= type.to_s == "notice" ? "bg-hero-yellow" : "bg-white" %> px-4 py-3 text-base font-semibold text-ink shadow-comic-sm sm:text-sm" role="<%= type.to_s == "notice" ? "status" : "alert" %>">
            <%= message %>
          </div>
        <% end %>
        <%= yield %>
      </main>

      <footer class="mt-10 border-t-3 border-ink bg-white">
        <div class="flex flex-wrap items-center justify-between gap-2 px-6 py-4 sm:px-10">
          <p class="text-base text-ink/70 sm:text-sm"><%= t("layout.footer_tagline") %></p>
          <p class="font-display text-sm tracking-wide text-ink/60" dir="ltr"><%= t("layout.footer_issue") %></p>
        </div>
      </footer>
    </div>
  </body>
</html>
