<!DOCTYPE html>
<html lang="<%= I18n.locale %>" dir="<%= text_direction %>" class="antialiased">
  <head>
    <%= display_meta_tags(default_meta_tags) %>

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="view-transition" content="same-origin">
    <meta name="application-name" content="pastehtml.dev">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="pastehtml">
    <meta name="theme-color" content="#fff8ec">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <% unless paste_origin_request? %>
      <%# PWA manifest for installable apps (routes are defined in config/routes.rb).
          The manifest fetch carries no cookie, so non-default locales travel in the href. %>
      <%= tag.link rel: "manifest", href: (I18n.locale == I18n.default_locale ? pwa_manifest_path : pwa_manifest_path(locale: I18n.locale)) %>
    <% end %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://rsms.me/">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bangers&family=IBM+Plex+Mono:wght@400;500&display=swap">
    <%# Arabic comic + text faces, loaded only when the page is Arabic so English stays lean. %>
    <% if I18n.locale == :ar %>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600&family=Lalezar&display=swap">
    <% end %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-paper font-sans text-ink"<% unless paste_origin_request? %> data-controller="pwa"<% end %>>
    <div class="isolate flex min-h-dvh flex-col overflow-x-clip">
      <a href="#main" class="sr-only focus-visible:not-sr-only focus-visible:absolute focus-visible:start-3 focus-visible:top-3 focus-visible:z-50 focus-visible:rounded-md focus-visible:border-3 focus-visible:border-ink focus-visible:bg-white focus-visible:px-4 focus-visible:py-2 focus-visible:font-display focus-visible:text-ink focus-visible:shadow-comic-sm"><%= t("layout.skip_to_content") %></a>
      <header class="flex items-center justify-between gap-2 px-4 py-4 sm:gap-4 sm:px-10 sm:py-5">
        <a href="/" dir="ltr" aria-label="pastehtml.dev" class="inline-flex size-11 shrink-0 items-center justify-center -rotate-1 border-3 border-ink bg-white font-display text-xl tracking-wide shadow-comic-sm sm:size-auto sm:px-3 sm:py-1 sm:text-2xl">
          <span class="sm:hidden">P<span class="text-hero-red">.</span></span>
          <span class="hidden sm:inline">pastehtml<span class="text-hero-red">.dev</span></span>
        </a>
        <div class="flex items-center justify-end gap-2.5 sm:gap-3">
          <nav aria-label="<%= t("layout.primary_nav") %>" class="flex items-center gap-2.5 sm:gap-3">
          <%# On mobile each nav item shows only its icon (label hidden) to keep the
              header on one uncrowded row; the text label returns from the sm breakpoint. %>
          <% if authenticated? %>
            <% dashboard_current = current_nav?(:dashboard) %>
            <%= link_to pastes_path, aria: { label: t("layout.dashboard"), current: ("page" if dashboard_current) },
                  class: "inline-flex items-center sm:rotate-1 border-2 border-ink p-2.5 font-display text-xs tracking-wide shadow-comic-sm sm:px-2.5 sm:py-1 sm:text-sm #{dashboard_current ? "bg-ink text-paper" : "bg-hero-yellow text-ink hover:bg-white"}" do %>
              <%= nav_icon(:dashboard) %><span class="hidden sm:inline"><%= t("layout.dashboard") %></span>
            <% end %>
            <% api_keys_current = current_nav?(:api_keys) %>
            <%= link_to api_keys_path, aria: { label: t("layout.api_keys"), current: ("page" if api_keys_current) },
                  class: "inline-flex items-center sm:-rotate-1 border-2 border-ink p-2.5 font-display text-xs tracking-wide shadow-comic-sm sm:px-2.5 sm:py-1 sm:text-sm #{api_keys_current ? "bg-ink text-paper" : "bg-white text-ink hover:bg-hero-yellow"}" do %>
              <%= nav_icon(:api_keys) %><span class="hidden sm:inline"><%= t("layout.api_keys") %></span>
            <% end %>
            <%= button_to session_path, method: :delete, aria: { label: t("layout.sign_out") },
                  class: "inline-flex items-center border-2 border-ink bg-white p-2.5 font-display text-xs tracking-wide text-ink shadow-comic-sm hover:bg-hero-yellow sm:px-2.5 sm:py-1 sm:text-sm" do %>
              <%= nav_icon(:sign_out) %><span class="hidden sm:inline"><%= t("layout.sign_out") %></span>
            <% end %>
          <% else %>
            <% sign_in_current = current_nav?(:sign_in) %>
            <%= link_to new_session_path, aria: { label: t("layout.sign_in"), current: ("page" if sign_in_current) },
                  class: "inline-flex items-center sm:rotate-2 border-2 border-ink p-2.5 font-display text-xs tracking-wide shadow-comic-sm sm:px-2.5 sm:py-1 sm:text-sm #{sign_in_current ? "bg-ink text-paper" : "bg-white text-ink hover:bg-hero-yellow"}" do %>
              <%= nav_icon(:sign_in) %><span class="hidden sm:inline"><%= t("layout.sign_in") %></span>
            <% end %>
            <% sign_up_current = current_nav?(:sign_up) %>
            <%= link_to new_user_path, aria: { label: t("layout.sign_up"), current: ("page" if sign_up_current) },
                  class: "inline-flex items-center sm:-rotate-1 border-2 border-ink p-2.5 font-display text-xs tracking-wide shadow-comic-sm sm:px-2.5 sm:py-1 sm:text-sm #{sign_up_current ? "bg-ink text-paper" : "bg-hero-yellow text-ink hover:bg-white"}" do %>
              <%= nav_icon(:sign_up) %><span class="hidden sm:inline"><%= t("layout.sign_up") %></span>
            <% end %>
          <% end %>
          </nav>
          <%= locale_toggle %>
        </div>
      </header>

      <main id="main" class="flex flex-1 flex-col">
        <% flash.each do |type, message| %>
          <% next if message.blank? %>
          <%# data-turbo-temporary: Turbo strips this before caching the page, so a
              cached back-navigation never flashes a stale message. %>
          <div data-controller="dismiss" data-turbo-temporary role="<%= type.to_s == "notice" ? "status" : "alert" %>"
               class="mx-auto mt-2 flex w-[calc(100%-2rem)] max-w-4xl items-start justify-between gap-3 rounded-lg border-3 border-ink <%= type.to_s == "notice" ? "bg-hero-yellow" : "bg-white" %> px-4 py-3 text-base font-semibold text-ink shadow-comic-sm sm:w-[calc(100%-3rem)] sm:text-sm">
            <span><%= message %></span>
            <button type="button" data-action="dismiss#dismiss" aria-label="<%= t("layout.dismiss") %>"
                    class="-me-1 shrink-0 rounded p-0.5 text-ink/50 hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-hero-blue">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="size-4" aria-hidden="true">
                <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
              </svg>
            </button>
          </div>
        <% end %>
        <%= yield %>
      </main>

      <footer class="mt-10 border-t-3 border-ink bg-white">
        <div class="flex flex-wrap items-center justify-between gap-2 px-6 py-4 sm:px-10">
          <p class="text-base text-ink/70 sm:text-sm"><%= t("layout.footer_tagline") %></p>
          <p class="font-display text-sm tracking-wide text-ink/60" dir="ltr"><%= t("layout.footer_issue") %></p>
        </div>
      </footer>
    </div>
  </body>
</html>
