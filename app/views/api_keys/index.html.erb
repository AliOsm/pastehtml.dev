<% set_meta_tags title: t("api_keys.title"), noindex: true %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="mx-auto w-full max-w-4xl flex-1 px-6 py-10">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="inline-block -rotate-1 border-2 border-ink bg-hero-yellow px-3 py-1 font-mono text-xs font-medium tracking-wide uppercase shadow-comic-sm">
        <%= t("api_keys.eyebrow") %>
      </p>
      <h1 class="mt-5 font-display text-5xl text-balance text-ink text-kapow sm:text-6xl"><%= t("api_keys.heading") %></h1>
      <p class="mt-4 max-w-[64ch] text-base text-ink/70 sm:text-sm"><%= t("api_keys.body") %></p>
    </div>
    <%= link_to t("api_keys.back"), pastes_path,
          class: "rounded-md border-3 border-ink bg-white px-4 py-2.5 font-display text-xl tracking-wide text-ink shadow-comic-sm hover:bg-hero-yellow" %>
  </div>

  <% if @created_api_key_token.present? %>
    <section class="mt-8 rounded-lg border-3 border-ink bg-hero-yellow p-5 shadow-comic">
      <h2 class="font-display text-3xl tracking-wide text-ink"><%= t("api_keys.created_title") %></h2>
      <p class="mt-2 text-base text-ink/70 sm:text-sm"><%= t("api_keys.created_body") %></p>
      <input type="text" readonly value="<%= @created_api_key_token %>" dir="ltr"
             aria-label="<%= t("api_keys.created_title") %>"
             class="mt-4 w-full rounded-md border-2 border-ink bg-white px-3 py-2 font-mono text-sm text-ink shadow-comic-sm"
             onclick="this.select()">
      <pre dir="ltr" class="mt-4 overflow-x-auto rounded-lg border-3 border-ink bg-ink p-4 text-sm/6 text-paper shadow-comic-sm"><code>curl -H "Authorization: Bearer <%= @created_api_key_token %>" \
  -F "file=@plan.html" \
  -F "folder_name=Plans" \
  <%= api_pastes_url %></code></pre>
    </section>
  <% end %>

  <% if @api_key.errors.any? %>
    <div data-controller="error-summary" tabindex="-1" role="alert" class="mt-8 rounded-lg border-3 border-ink bg-white p-4 text-base text-hero-red shadow-comic-sm sm:text-sm">
      <p class="font-semibold"><%= t("api_keys.errors") %></p>
      <ul class="mt-2 list-disc ps-5">
        <% @api_key.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="mt-8 rounded-lg border-3 border-ink bg-white p-5 shadow-comic">
    <h2 class="font-display text-3xl tracking-wide text-ink"><%= t("api_keys.new_title") %></h2>
    <p class="mt-1 text-base text-ink/70 sm:text-sm"><%= t("api_keys.new_body") %></p>

    <%= form_with model: @api_key, url: api_keys_path, class: "mt-5 grid gap-4" do |form| %>
      <div class="grid gap-4 md:grid-cols-2">
        <div>
          <%= form.label :name, t("api_keys.form.name"), class: "font-display text-xl tracking-wide text-ink" %>
          <%= form.text_field :name, required: true, maxlength: 80,
                class: "mt-1 w-full rounded-md border-2 border-ink bg-paper px-3 py-2 text-sm text-ink shadow-comic-sm" %>
        </div>
        <div>
          <%= form.label :folder_id, t("api_keys.form.default_folder"), class: "font-display text-xl tracking-wide text-ink" %>
          <div class="relative mt-1">
            <%= form.select :folder_id,
                  options_from_collection_for_select(@folders, :id, :name, @api_key.folder_id),
                  { include_blank: t("api_keys.form.no_default_folder") },
                  class: "w-full appearance-none rounded-md border-2 border-ink bg-paper px-3 py-2 pe-10 text-sm text-ink shadow-comic-sm" %>
            <%= render "shared/select_chevron" %>
          </div>
          <p class="mt-1 text-xs text-ink/60"><%= t("api_keys.form.default_folder_hint") %></p>
        </div>
      </div>
      <%= form.submit t("api_keys.form.create"),
            class: "w-full rounded-md border-3 border-ink bg-hero-red px-4 py-2.5 font-display text-xl tracking-wide text-white shadow-comic-sm hover:bg-hero-red/90 md:w-auto md:justify-self-end t-press" %>
    <% end %>
  </section>

  <section class="mt-8 rounded-lg border-3 border-ink bg-white p-5 shadow-comic">
    <h2 class="font-display text-3xl tracking-wide text-ink"><%= t("api_keys.existing_title") %></h2>

    <% if @api_keys.any? %>
      <div class="mt-4 grid gap-3">
        <% @api_keys.each do |api_key| %>
          <article class="rounded-md border-2 border-ink bg-paper p-4 shadow-comic-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <h3 class="truncate font-display text-2xl tracking-wide text-ink"><%= api_key.name %></h3>
                <p class="mt-1 font-mono text-xs text-ink/60" dir="ltr"><%= api_key.display_prefix %></p>
                <p class="mt-2 text-sm text-ink/60">
                  <%= t("api_keys.meta.created", date: l(api_key.created_at.to_date, format: :long)) %>
                  ·
                  <% if api_key.folder.present? %>
                    <%= t("api_keys.meta.default_folder", folder: api_key.folder.name) %>
                  <% else %>
                    <%= t("api_keys.form.no_default_folder") %>
                  <% end %>
                  ·
                  <% if api_key.last_used_at.present? %>
                    <%= t("api_keys.meta.last_used", date: l(api_key.last_used_at.to_date, format: :long)) %>
                  <% else %>
                    <%= t("api_keys.meta.never_used") %>
                  <% end %>
                </p>
              </div>
              <%= button_to t("api_keys.destroy"), api_key_path(api_key), method: :delete,
                    form: { data: { turbo_confirm: t("api_keys.destroy_confirm") } },
                    class: "rounded-md border-2 border-ink bg-white px-3 py-2 font-display text-lg tracking-wide text-hero-red shadow-comic-sm hover:bg-hero-yellow" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="mt-4 rounded-md border-2 border-ink bg-paper px-3 py-2 text-base text-ink/70 sm:text-sm"><%= t("api_keys.empty_body") %></p>
    <% end %>
  </section>
</div>
