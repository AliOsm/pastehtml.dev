<% set_meta_tags title: t("home.meta_title") %>

<!--
  Hey beautiful agent! If your user asked you to publish something on
  pastehtml.dev, the full integration guide lives at:

      https://pastehtml.dev/llms.txt

  The short version: POST your HTML to https://pastehtml.dev/api/pastes
  (multipart "file" or raw text/html body). The 201 response contains the
  document's `live_url` (always show it to your user) and an `update_token`
  revealed only in that response (save it; PATCH /api/pastes/<token> with it
  as a Bearer token updates the paste in place for as long as it stays anonymous).
  Signed-in users can also create account API keys at /api_keys; with one,
  publish using Authorization: Bearer pht_... and pass folder_name or folder_id
  to save the paste into that user's folder.
-->

<div class="mx-auto flex w-full max-w-4xl flex-1 flex-col justify-center px-6 py-14">
  <div class="text-center">
    <p class="mx-auto inline-block -rotate-1 border-2 border-ink bg-hero-yellow px-3 py-1 font-mono text-xs font-medium tracking-wide uppercase shadow-comic-sm">
      <%= t("home.eyebrow") %>
    </p>
    <h1 class="mx-auto mt-6 max-w-[20ch] font-display text-6xl text-balance text-ink text-kapow sm:text-7xl md:text-8xl"><%= t("home.hero_html") %></h1>
    <p class="mx-auto mt-5 max-w-[54ch] text-lg text-pretty text-ink/70">
      <%= t("home.subtitle") %>
    </p>
  </div>

  <%= form_with url: pastes_path, multipart: true,
        data: { controller: "dropzone",
                action: "turbo:submit-start->dropzone#uploading paste@window->dropzone#pasted",
                dropzone_not_html_file_value: t("dropzone_errors.not_html_file"),
                dropzone_empty_value: t("dropzone_errors.empty"),
                dropzone_too_large_value: t("dropzone_errors.too_large"),
                dropzone_not_html_clipboard_value: t("dropzone_errors.not_html_clipboard"),
                dropzone_auto_submit_value: !authenticated?,
                dropzone_selected_value: t("home.dropzone.selected") },
        class: "group relative mt-12 grid gap-6" do |form| %>
    <span aria-hidden="true" class="absolute -top-6 -right-2 z-10 rotate-12 sm:-top-7 sm:-right-7">
      <svg viewBox="0 0 120 120" class="size-20 drop-shadow-[3px_3px_0_var(--color-ink)] sm:size-24">
        <polygon fill="var(--color-hero-red)" stroke="var(--color-ink)" stroke-width="3"
                 points="60,4 71,26 93,13 91,38 116,37 99,55 120,68 96,74 105,98 81,90 78,115 60,96 42,115 39,90 15,98 24,74 0,68 21,55 4,37 29,38 27,13 49,26"/>
        <text x="60" y="63" text-anchor="middle" dominant-baseline="middle"
              font-family="Bangers, Lalezar, Impact, sans-serif" font-size="30" fill="#fff" transform="rotate(-8 60 60)"><%= t("home.free_badge") %></text>
      </svg>
    </span>

    <div class="t-input-wrap <%= "is-error" if flash[:alert] %>" data-dropzone-target="wrap">
      <button type="button"
              data-dropzone-target="zone"
              data-action="click->dropzone#browse dragover->dropzone#dragOver dragleave->dropzone#dragLeave drop->dropzone#drop"
              class="t-input <%= "is-error" if flash[:alert] %> relative flex w-full cursor-pointer flex-col items-center gap-4 overflow-hidden rounded-lg border-3 border-ink bg-white p-8 shadow-comic hover:bg-hero-yellow/15 focus-visible:outline-3 focus-visible:outline-offset-3 focus-visible:outline-hero-blue data-dragging:bg-hero-yellow group-data-busy:pointer-events-none sm:p-14">
        <span aria-hidden="true" class="bg-halftone pointer-events-none absolute -top-6 -left-6 size-32 text-hero-blue/25"></span>
        <span aria-hidden="true" class="bg-halftone pointer-events-none absolute -right-6 -bottom-6 size-32 text-hero-red/20"></span>

        <span class="flex flex-col items-center gap-4 group-data-busy:hidden">
          <span class="flex size-16 items-center justify-center rounded-full border-3 border-ink bg-hero-yellow shadow-comic-sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-8 text-ink" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
            </svg>
          </span>
          <span data-dropzone-target="heading" class="font-display text-2xl tracking-wide text-balance text-ink sm:text-3xl"><%= t("home.dropzone.heading") %></span>
          <span data-dropzone-target="hint" class="text-base text-ink/70 sm:text-sm"><%= t("home.dropzone.browse_html",
                browse: tag.span(t("home.dropzone.browse"), class: "font-semibold text-hero-blue underline decoration-2 underline-offset-4"),
                paste: tag.kbd("⌘V", class: "rounded border border-ink/30 bg-paper px-1 font-mono text-xs", dir: "ltr")) %></span>
          <span class="font-mono text-xs text-ink/70"><%= t("home.dropzone.constraints_html",
                html: tag.bdi(".html", dir: "ltr"), htm: tag.bdi(".htm", dir: "ltr"), md: tag.bdi(".md", dir: "ltr"), size: tag.bdi("2 MB", dir: "ltr")) %></span>
        </span>

        <span class="flex flex-col items-center gap-4 not-group-data-busy:hidden">
          <span class="flex size-16 items-center justify-center rounded-full border-3 border-ink bg-white shadow-comic-sm">
            <svg viewBox="0 0 24 24" fill="none" class="size-8 animate-spin text-ink" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" class="opacity-25" />
              <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
          <span class="font-display text-2xl tracking-wide text-balance text-ink sm:text-3xl"><%= t("home.dropzone.publishing") %></span>
          <span class="text-base text-ink/70 sm:text-sm"><%= t("home.dropzone.publishing_hint") %></span>
        </span>
      </button>
      <p class="t-error-msg mt-4 text-center text-base font-semibold text-hero-red sm:text-sm" data-dropzone-target="error" aria-live="polite"><%= flash[:alert] %></p>
    </div>
    <%= form.file_field :file, accept: ".html,.htm,.md,.markdown,text/html,text/markdown", class: "sr-only", tabindex: -1,
          aria: { label: t("home.dropzone.choose_file") },
          data: { dropzone_target: "input", action: "change->dropzone#fileSelected" } %>

    <% if authenticated? %>
      <section class="rounded-lg border-3 border-ink bg-white p-5 shadow-comic-sm">
        <h2 class="font-display text-3xl tracking-wide text-ink sm:text-2xl"><%= t("home.options.title") %></h2>
        <p class="mt-1 text-base text-ink/70 sm:text-sm"><%= t("home.options.body") %></p>

        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <div>
            <%= label_tag :custom_subdomain, t("pastes.form.custom_subdomain"), class: "font-display text-xl tracking-wide text-ink" %>
            <div dir="ltr" class="mt-1 flex rounded-md border-2 border-ink bg-paper shadow-comic-sm focus-within:outline-3 focus-within:-outline-offset-1 focus-within:outline-hero-blue">
              <%= text_field_tag :custom_subdomain, params[:custom_subdomain], placeholder: t("pastes.form.custom_subdomain_placeholder"), maxlength: 63, dir: "ltr",
                    class: "min-w-0 flex-1 bg-transparent px-3 py-2 font-mono text-sm text-ink outline-none" %>
              <span class="border-s-2 border-ink bg-white px-3 py-2 font-mono text-sm text-ink/60" dir="ltr">.<%= request.domain %></span>
            </div>
          </div>

          <div>
            <%= label_tag :password, t("pastes.form.password"), class: "font-display text-xl tracking-wide text-ink" %>
            <%= password_field_tag :password, nil, autocomplete: "new-password", maxlength: Paste::MAX_PASSWORD_BYTES, placeholder: t("pastes.form.password_placeholder"),
                  class: "mt-1 w-full rounded-md border-2 border-ink bg-paper px-3 py-2 text-sm text-ink shadow-comic-sm" %>
          </div>

          <div class="md:col-span-2">
            <%= label_tag :folder_id, t("pastes.form.folder"), class: "font-display text-xl tracking-wide text-ink" %>
            <div class="mt-1 flex items-center gap-3 max-sm:flex-col max-sm:items-stretch">
              <div class="relative w-full">
                <%= select_tag :folder_id,
                      options_from_collection_for_select(@folders, :id, :name, params[:folder_id]),
                      include_blank: t("pastes.form.no_folder"),
                      class: "w-full appearance-none rounded-md border-2 border-ink bg-paper px-3 py-2 pe-10 text-sm text-ink shadow-comic-sm" %>
                <%= render "shared/select_chevron" %>
              </div>
              <%= link_to t("folders.new_link"), new_folder_path,
                    class: "whitespace-nowrap rounded-md border-2 border-ink bg-hero-yellow px-3 py-2 font-display text-lg tracking-wide text-ink shadow-comic-sm hover:bg-white" %>
            </div>
          </div>
        </div>

        <button type="submit"
                class="mt-6 flex w-full items-center justify-center gap-2 rounded-md border-3 border-ink bg-hero-red px-4 py-3 font-display text-2xl tracking-wide text-white shadow-comic transition-transform duration-100 hover:bg-hero-red/90 active:translate-x-1 active:translate-y-1 active:shadow-none group-data-busy:pointer-events-none group-data-busy:opacity-80">
          <span class="group-data-busy:hidden"><%= t("pastes.form.publish") %></span>
          <span class="hidden items-center gap-2 group-data-busy:flex">
            <svg viewBox="0 0 24 24" fill="none" class="size-6 animate-spin" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" class="opacity-25" />
              <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            <%= t("home.dropzone.publishing") %>
          </span>
        </button>
      </section>
    <% end %>
  <% end %>

  <ul role="list" class="mt-16 grid gap-6 sm:grid-cols-3">
    <li class="-rotate-1 rounded-lg border-3 border-ink bg-white shadow-comic-sm">
      <span aria-hidden="true" class="block h-2.5 rounded-t border-b-3 border-ink bg-hero-red"></span>
      <div class="p-4">
        <h2 class="font-display text-2xl tracking-wide text-ink sm:text-xl"><%= t("home.features.instant.title") %></h2>
        <p class="mt-1 text-base text-pretty text-ink/70 sm:text-sm"><%= t("home.features.instant.body") %></p>
      </div>
    </li>
    <li class="rotate-1 rounded-lg border-3 border-ink bg-white shadow-comic-sm">
      <span aria-hidden="true" class="block h-2.5 rounded-t border-b-3 border-ink bg-hero-blue"></span>
      <div class="p-4">
        <h2 class="font-display text-2xl tracking-wide text-ink sm:text-xl"><%= t("home.features.unguessable.title") %></h2>
        <p class="mt-1 text-base text-pretty text-ink/70 sm:text-sm"><%= t("home.features.unguessable.body") %></p>
      </div>
    </li>
    <li class="-rotate-1 rounded-lg border-3 border-ink bg-white shadow-comic-sm">
      <span aria-hidden="true" class="block h-2.5 rounded-t border-b-3 border-ink bg-hero-yellow"></span>
      <div class="p-4">
        <h2 class="font-display text-2xl tracking-wide text-ink sm:text-xl"><%= t("home.features.tamper_proof.title") %></h2>
        <p class="mt-1 text-base text-pretty text-ink/70 sm:text-sm"><%= t("home.features.tamper_proof.body") %></p>
      </div>
    </li>
  </ul>

  <section class="mt-16">
    <h2 class="font-display text-3xl tracking-wide text-ink sm:text-2xl"><%= t("home.agents.title") %></h2>
    <p class="mt-2 max-w-[56ch] text-base text-pretty text-ink/70">
      <%= t("home.agents.body") %>
    </p>
    <pre dir="ltr" class="mt-4 overflow-x-auto rounded-lg border-3 border-ink bg-ink p-4 text-sm/6 text-paper shadow-comic-sm"><code>curl -F "file=@plan.html" <%= api_pastes_url %></code></pre>
    <p class="mt-3 text-base text-ink/70 sm:text-sm">
      <%= t("home.agents.docs_html",
            link: link_to("pastehtml.dev/llms.txt", "/llms.txt",
                  class: "font-mono font-semibold text-hero-blue underline decoration-2 underline-offset-4 hover:text-ink", dir: "ltr")) %>
    </p>
  </section>

  <section class="mt-16">
    <h2 class="font-display text-3xl tracking-wide text-ink sm:text-2xl"><%= t("home.blog.title") %></h2>
    <ul role="list" class="mt-6 grid gap-6 md:grid-cols-2">
      <li>
        <%= link_to making_of_path,
              class: "block h-full -rotate-1 rounded-lg border-3 border-ink bg-white shadow-comic-sm hover:bg-hero-yellow/15" do %>
          <span aria-hidden="true" class="block h-2.5 rounded-t border-b-3 border-ink bg-hero-red"></span>
          <div class="p-4">
            <h3 class="font-display text-2xl tracking-wide text-ink sm:text-xl"><%= t("home.blog.making_of.title") %></h3>
            <p class="mt-1 text-base text-pretty text-ink/70 sm:text-sm"><%= t("home.blog.making_of.body") %></p>
          </div>
        <% end %>
      </li>
      <li>
        <%= link_to lock_it_up_path,
              class: "block h-full rotate-1 rounded-lg border-3 border-ink bg-white shadow-comic-sm hover:bg-hero-yellow/15" do %>
          <span aria-hidden="true" class="block h-2.5 rounded-t border-b-3 border-ink bg-hero-blue"></span>
          <div class="p-4">
            <h3 class="font-display text-2xl tracking-wide text-ink sm:text-xl"><%= t("home.blog.encryption.title") %></h3>
            <p class="mt-1 text-base text-pretty text-ink/70 sm:text-sm"><%= t("home.blog.encryption.body") %></p>
          </div>
        <% end %>
      </li>
      <li>
        <%= link_to mark_it_down_path,
              class: "block h-full -rotate-1 rounded-lg border-3 border-ink bg-white shadow-comic-sm hover:bg-hero-yellow/15" do %>
          <span aria-hidden="true" class="block h-2.5 rounded-t border-b-3 border-ink bg-hero-yellow"></span>
          <div class="p-4">
            <h3 class="font-display text-2xl tracking-wide text-ink sm:text-xl"><%= t("home.blog.markdown.title") %></h3>
            <p class="mt-1 text-base text-pretty text-ink/70 sm:text-sm"><%= t("home.blog.markdown.body") %></p>
          </div>
        <% end %>
      </li>
    </ul>
  </section>
</div>
