<% set_meta_tags title: t("pastes.edit.title", title: @paste.display_title), noindex: true %>

<div class="mx-auto w-full max-w-3xl flex-1 px-6 py-10">
  <p class="inline-block -rotate-1 border-2 border-ink bg-hero-yellow px-3 py-1 font-mono text-xs font-medium tracking-wide uppercase shadow-comic-sm">
    <%= t("pastes.edit.eyebrow") %>
  </p>
  <h1 class="mt-5 font-display text-5xl text-balance text-ink text-kapow sm:text-6xl"><%= t("pastes.edit.heading") %></h1>
  <p class="mt-4 text-base text-ink/70 sm:text-sm">
    <span class="font-semibold text-ink"><%= @paste.display_title %></span>
    · <span dir="ltr" class="break-all"><%= paste_live_url(@paste) %></span>
  </p>

  <% if @paste.errors.any? %>
    <div data-controller="error-summary" tabindex="-1" role="alert" class="mt-6 rounded-lg border-3 border-ink bg-white p-4 text-base text-hero-red shadow-comic-sm sm:text-sm">
      <p class="font-semibold"><%= t("pastes.form.errors") %></p>
      <ul class="mt-2 list-disc ps-5">
        <% @paste.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: owned_paste_path(@paste), method: :patch, multipart: true, class: "mt-8 grid gap-6 rounded-lg border-3 border-ink bg-white p-5 shadow-comic" do |form| %>
    <div>
      <%= form.label :file, t("pastes.form.reupload"), class: "font-display text-2xl tracking-wide text-ink" %>
      <%= form.file_field :file, accept: ".html,.htm,.md,.markdown,text/html,text/markdown",
            class: "mt-2 w-full rounded-md border-2 border-ink bg-paper px-3 py-2 text-sm text-ink shadow-comic-sm" %>
      <p class="mt-2 text-sm text-ink/60"><%= t("pastes.form.reupload_hint") %></p>
    </div>

    <div>
      <%= label_tag :custom_subdomain, t("pastes.form.custom_subdomain"), class: "font-display text-2xl tracking-wide text-ink" %>
      <div dir="ltr" class="mt-2 flex rounded-md border-2 border-ink bg-paper shadow-comic-sm focus-within:outline-3 focus-within:-outline-offset-1 focus-within:outline-hero-blue">
        <%= text_field_tag :custom_subdomain, @paste.custom_subdomain, placeholder: t("pastes.form.custom_subdomain_placeholder"), maxlength: 63, dir: "ltr",
              class: "min-w-0 flex-1 bg-transparent px-3 py-2 font-mono text-sm text-ink outline-none" %>
        <span class="border-s-2 border-ink bg-white px-3 py-2 font-mono text-sm text-ink/60" dir="ltr">.<%= request.domain %></span>
      </div>
    </div>

    <div>
      <%= label_tag :folder_id, t("pastes.form.folder"), class: "font-display text-2xl tracking-wide text-ink" %>
      <div class="relative mt-2">
        <%= select_tag :folder_id,
              options_from_collection_for_select(@folders, :id, :name, @paste.folder_id),
              include_blank: t("pastes.form.no_folder"),
              class: "w-full appearance-none rounded-md border-2 border-ink bg-paper px-3 py-2 pe-10 text-sm text-ink shadow-comic-sm" %>
        <%= render "shared/select_chevron" %>
      </div>
    </div>

    <div>
      <%= label_tag :password, t("pastes.form.new_password"), class: "font-display text-2xl tracking-wide text-ink" %>
      <%= password_field_tag :password, nil, autocomplete: "new-password", maxlength: Paste::MAX_PASSWORD_BYTES, placeholder: t("pastes.form.password_blank"),
            class: "mt-2 w-full rounded-md border-2 border-ink bg-paper px-3 py-2 text-sm text-ink shadow-comic-sm" %>
      <% if @paste.password_protected? %>
        <label class="mt-3 flex items-center gap-2 text-sm font-semibold text-ink">
          <%= check_box_tag :remove_password, "1", false, class: "size-4 rounded border-2 border-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-hero-blue" %>
          <%= t("pastes.form.remove_password") %>
        </label>
      <% end %>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= form.submit t("pastes.form.save"),
            class: "rounded-md border-3 border-ink bg-hero-red px-4 py-2.5 font-display text-2xl tracking-wide text-white shadow-comic-sm hover:bg-hero-red/90 t-press" %>
      <%= link_to t("pastes.form.cancel"), paste_path(@paste),
            class: "rounded-md border-3 border-ink bg-white px-4 py-2.5 font-display text-2xl tracking-wide text-ink shadow-comic-sm hover:bg-hero-yellow t-press" %>
    </div>
  <% end %>
</div>
