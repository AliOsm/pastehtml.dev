<div class="issue"><h2>انشُرها</h2></div>

<div class="panel">
  <h3>الخيار (أ) — السحب والإفلات</h3>
  <p>أفلِت ملفّ <code>.html</code> المُنزَّل على <a href="https://pastehtml.dev">pastehtml.dev</a> وانسخ
  رابط <code>https://&lt;token&gt;.pastehtml.dev/</code> الذي يمنحك إيّاه.</p>
</div>

<div class="panel">
  <h3>الخيار (ب) — واجهة الـ API (سطرٌ واحد)</h3>
  <p>صيَّرتَ ماركداونك إلى ملفّ مسبقًا؟ ارفعه مباشرةً من الطرفيّة:</p>
<pre dir="ltr"><code class="language-bash code-snippet">curl -F "file=@document.html" https://pastehtml.dev/api/pastes</code></pre>
  <p>ردُّ <code>201</code> يمنحك <code>live_url</code> القابل للمشاركة ورمز تحديثٍ <code>update_token</code>
  يُكشَف مرّةً واحدة — احفظه لتحدِّث الرابط نفسه بـ <code>PATCH</code> حين يتغيّر المستند. الدليل الكامل:
  <a href="https://pastehtml.dev/llms.txt">pastehtml.dev/llms.txt</a>.</p>
  <p style="margin-top:0.9rem">يمكن للوكلاء تخطّي المِسبَك تمامًا: حوِّل الماركداون إلى هذه القشرة في الخادم ثمّ انشره عبر <bdi dir="ltr">POST</bdi>.</p>
</div>

<div class="issue"><h2>ما الذي تُضمِّنه الأداة</h2></div>

<p>الملفّ المنشور ما هو إلا ماركداونك مضافًا إليه هذا المُصيِّر. وهذا هو قلبه — الشيفرة نفسها تعمل في
المعاينة أعلاه وفي كلّ صفحةٍ تبنيها:</p>

<pre dir="ltr"><code class="language-html code-snippet">&lt;script type="text/markdown" id="md"&gt;
# Your Markdown lives here, verbatim
&lt;/script&gt;
&lt;script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"&gt;&lt;/script&gt;
&lt;script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.11/dist/purify.min.js"&gt;&lt;/script&gt;
&lt;script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js"&gt;&lt;/script&gt;
&lt;script&gt;
  var raw = document.getElementById("md").textContent.replace(/&lt;\/(script)/gi, "&lt;/$1");
  var html = DOMPurify.sanitize(marked.parse(raw, { gfm: true }));
  document.getElementById("doc").innerHTML = html;
  document.querySelectorAll("#doc pre code").forEach(function (el) { hljs.highlightElement(el); });
&lt;/script&gt;</code></pre>

</div><!-- /#ar -->

<script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.11/dist/purify.min.js"></script>
<script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js"></script>
<script>
(function () {
  "use strict";

  function escapeHtml(s) {
    return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }
  // Escape only the closing script sequence so embedded Markdown can't end the
  // host <script type="text/markdown"> early. The renderer reverses this.
  function escapeForScript(s) {
    return String(s).replace(/<\/(script)/gi, "<\\/$1");
  }

  function render(rawMarkdown, target) {
    var raw = String(rawMarkdown).replace(/<\\\/(script)/gi, "</$1");
    var dirty = marked.parse(raw, { gfm: true, breaks: false });
    target.innerHTML = DOMPurify.sanitize(dirty);
    target.querySelectorAll("pre code").forEach(function (el) {
      try { hljs.highlightElement(el); } catch (e) {}
    });
  }

  var STR = {
    en: {
      needMd: "Write some Markdown first.",
      built: function (kb) { return "Built — " + kb + " KB, self-contained."; },
      copied: "Copied the full HTML to your clipboard.",
      clip: "Clipboard blocked — use Download instead.",
      defTitle: "My document", loading: "Rendering…",
      loadErr: "Could not load the renderer. Check your connection."
    },
    ar: {
      needMd: "اكتب بعض الماركداون أولاً.",
      built: function (kb) { return "بُنيت — " + kb + " كيلوبايت، مكتفية ذاتيًّا."; },
      copied: "نُسِخت صفحة HTML كاملةً إلى الحافظة.",
      clip: "تعذّر الوصول إلى الحافظة — استخدم التنزيل بدلاً منه.",
      defTitle: "مستندي", loading: "يجري العرض…",
      loadErr: "تعذّر تحميل المُصيِّر. تحقّق من اتصالك."
    }
  };

  // The .md-body CSS, reused verbatim in every generated page so preview ===
  // published output. Logical properties keep it correct in LTR and RTL.
  var PROSE = [
'  .md-body { max-width: 50rem; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; color: var(--ink); line-height: 1.65; }',
'  .md-body > :first-child { margin-top: 0; }',
'  .md-body h1, .md-body h2, .md-body h3, .md-body h4 { font-family: Bangers, Lalezar, Impact, sans-serif; letter-spacing: 0.02em; line-height: 1.2; margin: 1.8rem 0 0.7rem; }',
'  .md-body h1 { font-size: clamp(2.2rem,6vw,3rem); text-shadow: 2px 2px 0 var(--red); }',
'  .md-body h2 { font-size: 1.8rem; border-bottom: 3px solid var(--ink); padding-bottom: 0.2rem; }',
'  .md-body h3 { font-size: 1.4rem; } .md-body h4 { font-size: 1.15rem; }',
'  .md-body p { margin: 0.85rem 0; }',
'  .md-body a { color: var(--blue); text-decoration: underline; text-underline-offset: 2px; }',
'  .md-body ul, .md-body ol { margin: 0.85rem 0; padding-inline-start: 1.7rem; }',
'  .md-body li { margin: 0.3rem 0; }',
'  .md-body code { font-family: "IBM Plex Mono", "IBM Plex Sans Arabic", monospace; font-size: 0.85em; background: rgb(24 18 14 / 0.08); border-radius: 4px; padding: 0.08rem 0.34rem; unicode-bidi: isolate; }',
'  .md-body pre { direction: ltr; text-align: left; background: var(--ink); border: 3px solid var(--ink); border-radius: 12px; box-shadow: 5px 5px 0 0 var(--red); padding: 1rem 1.1rem; overflow-x: auto; margin: 1.1rem 0; }',
'  .md-body pre code { background: none; padding: 0; font-size: 0.85rem; line-height: 1.55; }',
'  .md-body blockquote { border-inline-start: 6px solid var(--yellow); background: #fff7d6; margin: 1.1rem 0; padding: 0.6rem 1rem; border-radius: 8px; border-start-start-radius: 0; border-end-start-radius: 0; }',
'  .md-body blockquote > :first-child { margin-top: 0; } .md-body blockquote > :last-child { margin-bottom: 0; }',
'  .md-body table { border-collapse: collapse; margin: 1.1rem 0; width: 100%; display: block; overflow-x: auto; }',
'  .md-body th, .md-body td { border: 2px solid var(--ink); padding: 0.45rem 0.7rem; text-align: start; }',
'  .md-body th { background: var(--yellow); font-family: "IBM Plex Mono", "IBM Plex Sans Arabic", monospace; font-size: 0.9rem; }',
'  .md-body img { max-width: 100%; height: auto; border: 3px solid var(--ink); border-radius: 8px; }',
'  .md-body hr { border: none; border-top: 3px dashed rgb(24 18 14 / 0.3); margin: 1.8rem 0; }',
'  .md-body input[type="checkbox"] { width: 1rem; height: 1rem; vertical-align: middle; margin-inline-end: 0.3rem; }'
  ].join("\n");

  function buildPage(markdown, title, lang, S) {
    var dir = lang === "ar" ? "rtl" : "ltr";
    return [
'<!DOCTYPE html>',
'<html lang="' + lang + '" dir="' + dir + '">',
'<head>',
'<meta charset="utf-8">',
'<meta name="viewport" content="width=device-width, initial-scale=1">',
'<title>' + escapeHtml(title) + '</title>',
'<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>',
'<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bangers&family=Inter:wght@400;600;700&family=IBM+Plex+Mono:wght@400;500&family=Lalezar&family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap">',
'<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/styles/github-dark.min.css">',
'<style>',
'  :root { --ink:#18120e; --paper:#fff8ec; --red:#e62429; --yellow:#ffd400; --blue:#0072ce; }',
'  * { margin:0; box-sizing:border-box; }',
'  body { background-color:var(--paper);',
'    background-image:radial-gradient(circle, rgb(24 18 14 / 0.07) 1px, transparent 1.4px);',
'    background-size:12px 12px; color:var(--ink);',
'    font-family:Inter,"IBM Plex Sans Arabic",system-ui,sans-serif; -webkit-font-smoothing:antialiased; }',
'  [dir="rtl"] * { letter-spacing:normal; }',
PROSE,
'  .md-body .loading { font-family:"IBM Plex Mono","IBM Plex Sans Arabic",monospace; color:rgb(24 18 14 / 0.5); }',
'</style>',
'</head>',
'<body>',
'  <main class="md-body" id="doc"><p class="loading">' + escapeHtml(S.loading) + '</p></main>',
'  <script type="text/markdown" id="md">' + escapeForScript(markdown) + '<\/script>',
'  <script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"><\/script>',
'  <script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.11/dist/purify.min.js"><\/script>',
'  <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js"><\/script>',
'  <script>',
'  (function () {',
'    function go() {',
'      var raw = document.getElementById("md").textContent.replace(/<\\\\\\/(script)/gi, "<\\/$1");',
'      var doc = document.getElementById("doc");',
'      if (!window.marked || !window.DOMPurify) { doc.innerHTML = ' + JSON.stringify('<p class="loading">' + S.loadErr + '</p>') + '; return; }',
'      doc.innerHTML = DOMPurify.sanitize(marked.parse(raw, { gfm: true, breaks: false }));',
'      if (window.hljs) doc.querySelectorAll("pre code").forEach(function (el) { try { hljs.highlightElement(el); } catch (e) {} });',
'    }',
'    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", go); else go();',
'  })();',
'  <\/script>',
'</body>',
'</html>'
    ].join("\n");
  }

  function initForge(root, lang) {
    if (!root) return;
    var S = STR[lang] || STR.en;
    var input = root.querySelector(".f-md");
    var titleEl = root.querySelector(".f-title");
    var preview = root.querySelector(".f-preview");
    var statusEl = root.querySelector(".f-status");
    var buildBtn = root.querySelector(".f-build");
    var dlBtn = root.querySelector(".f-download");
    var copyBtn = root.querySelector(".f-copy");
    var builtHTML = null;

    function setStatus(msg, cls) { statusEl.textContent = msg; statusEl.className = "status f-status" + (cls ? " " + cls : ""); }
    function livePreview() { try { render(input.value, preview); } catch (e) {} }

    input.addEventListener("input", livePreview);
    livePreview();

    buildBtn.addEventListener("click", function () {
      var md = input.value;
      var title = (titleEl.value || "").trim() || S.defTitle;
      if (!md.trim()) { setStatus(S.needMd, "err"); return; }
      builtHTML = buildPage(md, title, lang, S);
      dlBtn.disabled = false; copyBtn.disabled = false;
      setStatus(S.built(Math.round(builtHTML.length / 1024)), "ok");
    });

    dlBtn.addEventListener("click", function () {
      if (!builtHTML) return;
      var blob = new Blob([builtHTML], { type: "text/html" });
      var url = URL.createObjectURL(blob);
      var a = document.createElement("a");
      a.href = url; a.download = "document.html";
      document.body.appendChild(a); a.click(); a.remove();
      setTimeout(function () { URL.revokeObjectURL(url); }, 1000);
    });

    copyBtn.addEventListener("click", async function () {
      if (!builtHTML) return;
      try { await navigator.clipboard.writeText(builtHTML); setStatus(S.copied, "ok"); }
      catch (e) { setStatus(S.clip, "err"); }
    });
  }

  initForge(document.getElementById("en"), "en");
  initForge(document.getElementById("ar"), "ar");

  // Highlight the static prose snippets (the curl commands and the renderer
  // listing). The live-preview/built-page code blocks are highlighted by
  // render()/the baked-in script, so we only touch the .code-snippet ones here.
  if (window.hljs) {
    document.querySelectorAll("pre code.code-snippet").forEach(function (el) {
      try { hljs.highlightElement(el); } catch (e) {}
    });
  }
})();
</script>

</div>
