# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# ghcr.io authenticates with a GitHub token taken from the gh CLI session.
GITHUB_TOKEN=$(gh config get -h github.com oauth_token)
KAMAL_REGISTRY_PASSWORD=$GITHUB_TOKEN

# Never check config/master.key into git!
RAILS_MASTER_KEY=$(cat config/master.key)

# Shared by the app (config/database.yml) and the postgres accessory.
# Export it in your shell before deploying: export POSTGRES_PASSWORD=...
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

# Cloudflare Origin CA certificate for "pastehtml.dev, *.pastehtml.dev"
# (Cloudflare dashboard -> SSL/TLS -> Origin Server -> Create Certificate).
# Files live in .kamal/certs/, which is gitignored.
CLOUDFLARE_ORIGIN_CERTIFICATE=$(cat .kamal/certs/origin.pem 2>/dev/null)
CLOUDFLARE_ORIGIN_KEY=$(cat .kamal/certs/origin-key.pem 2>/dev/null)
